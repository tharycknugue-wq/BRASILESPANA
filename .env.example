# BRASILESPAÑA · variáveis de ambiente
# Copie este arquivo para .env.local e preencha com suas credenciais.
# NUNCA commite o arquivo .env.local no git.

# ─── Supabase ───────────────────────────────────────────
# 1. Crie projeto em https://supabase.com
# 2. Settings → API → copie URL e anon public key abaixo
# 3. SQL Editor → cole o conteúdo de supabase/schema.sql e rode
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── PayPal (opcional, para assinatura) ─────────────────
# VITE_PAYPAL_CLIENT_ID=
# VITE_PAYPAL_PLAN_ID=

# ─── hCaptcha / Turnstile (opcional) ────────────────────
# VITE_HCAPTCHA_SITE_KEY=
